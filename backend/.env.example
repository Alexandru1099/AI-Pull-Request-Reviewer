APP_ENV=development
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_ALLOW_ORIGINS=http://localhost:3000

USE_MOCK_REVIEW=true
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PROMPT_TOKEN_PRICE=0.00000015
OPENAI_COMPLETION_TOKEN_PRICE=0.0000006

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
GITHUB_OAUTH_SCOPE=read:user repo
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_SESSION_TTL_SECONDS=604800
AUTH_STATE_TTL_SECONDS=600
